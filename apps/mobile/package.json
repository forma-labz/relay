{
  "name": "@relay/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --go",
    "start:go": "expo start --go",
    "start:go:ngrok": "node ./scripts/start-go-ngrok.mjs",
    "start:dev-client": "EXPO_PLATFORM=native expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "validate": "npm run format:check --prefix ../.. && npm run lint && npm run lint:css && npm run typecheck && npm test && npm run expo-check",
    "expo-check": "expo install --check --npm",
    "lint": "oxlint --type-aware --type-check -c .oxlintrc.json .",
    "lint:css": "node scripts/lint-css.mjs",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check ."
  },
