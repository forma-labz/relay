{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "base": {
      "node": "22.14.0",
      "env": {
        "EXPO_PLATFORM": "native",
        "EXPO_PUBLIC_DEMO_MODE": "false",
        "EXPO_PUBLIC_EAS_PROJECT_ID": "652fc2c3-5b20-48d3-9544-782c82e23c72"
      }
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "internal": {
      "extends": "base",
      "distribution": "internal",
      "channel": "internal"
    },
    "simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "extends": "base",
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft"
      },
      "ios": {
        "ascAppId": "$EXPO_ASC_APP_ID",
        "appleTeamId": "$EXPO_APPLE_TEAM_ID"
      }
    },
    "preview": {
      "extends": "production",
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    },
    "internal": {
      "extends": "production"
    }
  }
}
